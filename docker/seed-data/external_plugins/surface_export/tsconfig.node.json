{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"lib": ["es2023"],
		"module": "commonjs",
		"moduleResolution": "node",
		"target": "es2022",
		"outDir": ".",
		"rootDir": ".",
		"incremental": true,
		"sourceMap": true,
		"types": ["node"]
	},
	"include": [
		"helpers.ts",
		"messages.ts",
		"index.ts",
		"controller.ts",
		"instance.ts",
		"control.ts",
		"lib/**/*.ts"
	],
	"exclude": ["web/**", "dist/**", "node_modules/**", "webpack.config.js"]
}
