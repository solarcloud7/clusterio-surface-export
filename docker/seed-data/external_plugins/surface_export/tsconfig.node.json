{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"lib": ["es2023"],
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"target": "es2022",
		"outDir": "dist/node",
		"rootDir": ".",
		"incremental": true,
		"sourceMap": true,
		"types": ["node"],
		"paths": {
			"@clusterio/lib": ["../../../../clusterio/packages/lib/dist/node/index"],
			"@clusterio/controller": ["../../../../clusterio/packages/controller/dist/node/index"],
			"@clusterio/host": ["../../../../clusterio/packages/host/dist/node/index"],
			"@clusterio/ctl": ["../../../../clusterio/packages/ctl/dist/node/index"]
		}
	},
	"include": [
		"helpers.ts",
		"messages.ts",
		"index.ts",
		"controller.ts",
		"instance.ts",
		"control.ts",
		"lib/**/*.ts"
	],
	"exclude": ["web/**", "dist/web/**", "node_modules/**", "webpack.config.js"]
}
