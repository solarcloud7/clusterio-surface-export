{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"lib": ["dom", "dom.iterable", "es2023"],
		"module": "commonjs",
		"moduleResolution": "node",
		"target": "es2022",
		"jsx": "react-jsx",
		"types": ["node"],
		"noEmit": true
	},
	"include": [
		"helpers.ts",
		"messages.ts",
		"index.ts",
		"controller.ts",
		"instance.ts",
		"control.ts",
		"lib/**/*.ts",
		"web/**/*.tsx",
		"web/**/*.ts"
	],
	"exclude": ["dist/**", "node_modules/**"]
}
