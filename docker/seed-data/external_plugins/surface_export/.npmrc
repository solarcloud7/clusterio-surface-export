# Silence npm's "New minor version of npm available!" notice in build/lint/test output (#76).
# node:24 ships an older npm than the current release, so every `npm run` printed the update notice
# (build-plugin.ps1's isolated container AND CI, which run npm in this dir). Disabling the notifier clears
# it durably — bumping npm would just re-surface the notice on the next npm release. Behavior-neutral:
# update-notifier only controls that message, not install/resolution.
update-notifier=false
