{
  "name": "@solarcloud7/plugin-surface-export",
  "version": "0.9.195",
  "description": "Clusterio plugin for exporting and importing Factorio space platforms",
  "main": "dist/node/index.js",
  "types": "dist/node/index.d.ts",
  "scripts": {
    "build:node": "tsc -p tsconfig.node.json",
    "build:browser": "tsc -p tsconfig.browser.json --noEmit",
    "build:web": "webpack-cli --mode production",
    "build": "npm run build:node && npm run build:web",
    "prepare": "npm run build",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "keywords": [
    "clusterio",
    "factorio",
    "platform",
    "surface",
    "export",
    "clusterio-plugin"
  ],
  "author": "Solarcloud7",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solarcloud7/clusterio-surface-export.git",
    "directory": "docker/seed-data/external_plugins/surface_export"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/node/**/*.js",
    "dist/node/**/*.d.ts",
    "dist/web/",
    "module/",
    "package.json"
  ],
  "peerDependencies": {
    "@clusterio/lib": "2.0.0-alpha.22b",
    "@clusterio/controller": "2.0.0-alpha.22b",
    "@clusterio/host": "2.0.0-alpha.22b",
    "@clusterio/ctl": "2.0.0-alpha.22b"
  },
  "devDependencies": {
    "@clusterio/lib": "2.0.0-alpha.22b",
    "@clusterio/web_ui": "2.0.0-alpha.22b",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.65",
    "@types/react-dom": "^18.2.22",
    "antd": "^5.24.2",
    "mermaid": "^10.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.5.4",
    "webpack": "^5.98.0",
    "webpack-cli": "^5.1.4",
    "webpack-merge": "^5.9.0"
  }
}
