{
  "name": "@solarcloud7/plugin-surface-export",
  "version": "0.10.55",
  "description": "Clusterio plugin for exporting and importing Factorio space platforms",
  "main": "dist/node/index.js",
  "types": "dist/node/index.d.ts",
  "scripts": {
    "build:node": "tsc -p tsconfig.node.json",
    "build:browser": "tsc -p tsconfig.browser.json --noEmit",
    "build:web": "webpack-cli --mode production",
    "build": "npm run build:node && npm run build:web",
    "prepare": "npm run build",
    "lint": "npm run lint:js && npm run lint:lua && npm run lint:web-cache && npm run lint:test-grounding && npm run lint:pcall-logging && npm run lint:test-hooks",
    "lint:js": "eslint . --max-warnings 0",
    "lint:lua": "node scripts/lint-lua-invariants.mjs",
    "lint:web-cache": "node scripts/lint-webpack-cache.mjs",
    "lint:test-grounding": "node scripts/lint-test-grounding.mjs",
    "lint:pcall-logging": "node scripts/lint-pcall-logging.mjs",
    "lint:test-hooks": "node scripts/lint-test-hooks.mjs",
    "test": "npm run build:node && node --test test/messages.roundtrip.test.cjs test/transfer-orchestrator.rollback.test.cjs test/transfer-reconciliation.test.cjs"
  },
  "keywords": [
    "clusterio",
    "factorio",
    "platform",
    "surface",
    "export",
    "clusterio-plugin"
  ],
  "author": "Solarcloud7",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solarcloud7/clusterio-surface-export.git",
    "directory": "docker/seed-data/external_plugins/surface_export"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/node/**/*.js",
    "dist/node/**/*.d.ts",
    "dist/web/",
    "module/",
    "package.json"
  ],
  "peerDependencies": {
    "@clusterio/controller": "2.0.0-alpha.25",
    "@clusterio/ctl": "2.0.0-alpha.25",
    "@clusterio/host": "2.0.0-alpha.25",
    "@clusterio/lib": "2.0.0-alpha.25"
  },
  "devDependencies": {
    "@clusterio/controller": "2.0.0-alpha.25",
    "@clusterio/ctl": "2.0.0-alpha.25",
    "@clusterio/host": "2.0.0-alpha.25",
    "@clusterio/lib": "2.0.0-alpha.25",
    "@clusterio/web_ui": "2.0.0-alpha.25",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.65",
    "@types/react-dom": "^18.2.22",
    "antd": "^5.24.2",
    "eslint": "^9.39.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.61.0",
    "webpack": "^5.98.0",
    "webpack-cli": "^5.1.4",
    "webpack-merge": "^5.9.0"
  }
}
