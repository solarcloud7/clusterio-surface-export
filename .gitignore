
docs/dev-docs/

# Docker runtime data (stored in Docker volumes now)
docker/clusterio-containers/
clusterio/*

# Seed data - keep structure, ignore large binary files
docker/seed-data/mods/*
!docker/seed-data/mods/.gitkeep
docker/seed-data/hosts/**/*.zip

# Docker env files (contain credentials)
.env

# Legacy docker artifacts
docker/saves/
docker/logs/
docker/script-output/*.json
docker/config/
docker/server-settings.json

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.vscode
.claude

# Mod packaging
*.zip
# Seed saves needed for CI integration tests
!docker/seed-data/hosts/**/*.zip

# Built plugin artifacts (rebuild with npm run build)
docker/seed-data/external_plugins/surface_export/dist/

# TypeScript build output in plugin root and lib/ (should only be in dist/node/)
docker/seed-data/external_plugins/surface_export/*.js
docker/seed-data/external_plugins/surface_export/*.d.ts
docker/seed-data/external_plugins/surface_export/*.js.map
docker/seed-data/external_plugins/surface_export/*.d.ts.map
docker/seed-data/external_plugins/surface_export/*.tsbuildinfo
docker/seed-data/external_plugins/surface_export/lib/*.js
docker/seed-data/external_plugins/surface_export/lib/*.d.ts
docker/seed-data/external_plugins/surface_export/lib/*.js.map
docker/seed-data/external_plugins/surface_export/lib/*.d.ts.map

# Keep webpack config and web source files
!docker/seed-data/external_plugins/surface_export/webpack.config.js
!docker/seed-data/external_plugins/surface_export/web/*.js

# Node dependencies
**/node_modules/

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.log
